rules_version = '2';

// SHOS Med Global — Firestore security rules
//
// Deploy:  firebase deploy --only firestore:rules
//
// Design intent:
//   • Anyone can submit a contact message or booking request (no auth required)
//   • Authenticated users can read/write their own user record + sub-data
//   • Admin emails (see isAdmin() below) can read/write everything
//   • A public visits counter at _meta/siteStats accepts increment writes from
//     any visitor so the admin Total Visits card stays live.

service cloud.firestore {
  match /databases/{database}/documents {

    // ====== Helpers ======
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() && request.auth.token.email in [
        'eli@shosmed.com',
        'contact@shosmed.com',
        'privacy@shosmed.com',
        'elizolotov@gmail.com'
      ];
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ====== Users ======
    match /users/{uid} {
      allow read:   if isOwner(uid) || isAdmin();
      // Admin can create user docs so the "Grant QBank access" flow works
      // for Auth-only users (e.g. invited reviewers who haven't signed in
      // yet) — their Firestore profile gets created on demand.
      allow create: if isOwner(uid) || isAdmin();
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();

      // QBank progress + tests live as user sub-docs
      match /qbankData/{doc} {
        allow read, write: if isOwner(uid) || isAdmin();
      }
      match /qbankTests/{doc} {
        allow read:        if isOwner(uid) || isAdmin();
        allow create:      if isOwner(uid);
        allow update, delete: if isAdmin();
      }
      // Any other subcollection → owner + admin only
      match /{sub=**} {
        allow read, write: if isOwner(uid) || isAdmin();
      }
    }

    // ====== Messages (contact form) ======
    // Submission is open (visitors don't need to log in).
    // Reads + status updates are admin-only — fixes the bug where messages
    // submitted by anonymous visitors weren't visible to the admin.
    match /messages/{id} {
      allow read:   if isAdmin();
      allow create: if true;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ====== Bookings ======
    // Same submission rule. Authenticated users can read their own bookings;
    // admin reads all.
    match /bookings/{id} {
      allow read:   if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if true;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ====== Community Forum ======
    match /forum_posts/{id} {
      allow read:   if true;
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && resource.data.authorUid == request.auth.uid);
      allow delete: if isAdmin() || (isSignedIn() && resource.data.authorUid == request.auth.uid);

      match /{sub=**} {
        allow read: if true;
        allow write: if isSignedIn();
      }
    }

    // ====== Question Reports (QBank) ======
    // NOTE: the collection name is `questionReports` (camelCase) — that's
    // what qbank.js + dashboard.html both write/read. The previous rule
    // used `question_reports` (snake_case) which silently denied every
    // submission for the duration of that mismatch. Keep this name
    // EXACTLY as written; if you rename in code, rename here too.
    match /questionReports/{id} {
      allow read:           if isAdmin();
      allow create:         if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // ====== Community Forum: post votes ======
    // Composite doc ID is `{userId}_{postId}` so each user has at most
    // one vote per post. The user owns their own vote doc; admin reads
    // all for moderation / sanity checks.
    match /post_votes/{voteId} {
      allow read:   if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // ====== Community Forum: answer votes ======
    // Same shape as post_votes, scoped to answer documents under forum_posts.
    match /answer_votes/{voteId} {
      allow read:   if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // ====== Application Inquiries (LF3 apply-page form) ======
    // Public submit (no login required to express interest in applying);
    // admin-only read so the inbox isn't world-readable.
    match /application_inquiries/{id} {
      allow read:   if isAdmin();
      allow create: if true;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ====== Site stats (public increment, admin read) ======
    // Three documents are publicly writable so visit counters can
    // increment from any browser without auth:
    //   - siteStats         (total visits + lastVisitAt)
    //   - visitsByDay       (per-day counts for the admin chart)
    //   - visitsByCountry   (per-country counts for the admin chart)
    // All other _meta docs stay admin-only. Reads are admin-only across
    // the board (visit data is internal analytics, not user-visible).
    match /_meta/{doc} {
      allow read:  if isAdmin();
      allow write: if doc in ['siteStats', 'visitsByDay', 'visitsByCountry'];
    }
  }
}
